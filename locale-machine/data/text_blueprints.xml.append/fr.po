msgid ""
"data/text_blueprints.xml.append$//text[@name=\"ship_PLAYER_SHIP_TRASH_REACTOR_unlock\"]"
msgstr ""
"Gagnez le jeu avec n'importe quelle configuration du croiseur de collecte de"
