#: src-en/data/text_blueprints.xml.append:47
msgid ""
"data/text_blueprints.xml.append$//text[@name=\"text_PLAYER_SHIP_TRASH_EATER_desc\"]"
msgstr ""
"Le Prince de Lanius commande sa propre armée personnelle de Ferrailleurs - "
"il cherche à englober tellement de ferraille qu'il deviendra un énorme "
"vaisseau sentient, avec pour objectif final de dévorer le monde. Pour "
"l'instant... il a toujours la taille d'un membre d'équipage."

#: src-en/data/text_blueprints.xml.append:48
msgid ""
"data/text_blueprints.xml.append$//text[@name=\"ship_PLAYER_SHIP_TRASH_EATER_unlock\"]"
msgstr ""

