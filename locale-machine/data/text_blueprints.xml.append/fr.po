#: src-en/data/text_blueprints.xml.append:141
msgid ""
"data/text_blueprints.xml.append$//text[@name=\"text_PLAYER_SHIP_SLUGTON_2_desc\"]"
msgstr ""
"Ce vaisseau appartenait à la Kleptocratie des Limaces - sans surprise, c'est"
