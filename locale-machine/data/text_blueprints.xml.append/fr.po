#: src-en/data/text_blueprints.xml.append:146
msgid ""
"data/text_blueprints.xml.append$//text[@name=\"text_PLAYER_SHIP_SLUGTON_3_desc\"]"
msgstr ""
"Pourquoi Cheese a-t-il refait ce vaisseau et l'a-t-il amené dans la flotte "
"de la Fédération ? C'est une bonne question !"

