#: src-en/data/text_blueprints.xml.append:119
msgid ""
"data/text_blueprints.xml.append$//text[@name=\"text_PLAYER_SHIP_CORROSUS_desc\"]"
msgstr ""
"Une vieille amalgamation rouillée construite à partir des restes de "
"plusieurs autres vaisseaux. La RSA l'a dotée d'un équipage diversifié, "
"incluant un ferrailleur capturé."

#: src-en/data/text_blueprints.xml.append:120
msgid ""
"data/text_blueprints.xml.append$//text[@name=\"ship_PLAYER_SHIP_CORROSUS_unlock\"]"
msgstr ""
"Convainquez un certain renégat androïde de vous rejoindre ou gagnez le jeu "
"avec n'importe quelle configuration du Jet hybride de classe LPC."

#: src-en/data/text_blueprints.xml.append:122
msgid ""
"data/text_blueprints.xml.append$//text[@name=\"text_PLAYER_SHIP_CORROSUS_2_class\"]"
msgstr "Éclaireur RSA"

#: src-en/data/text_blueprints.xml.append:123
msgid ""
"data/text_blueprints.xml.append$//text[@name=\"text_PLAYER_SHIP_CORROSUS_2_name\"]"
msgstr "Wastebent"

