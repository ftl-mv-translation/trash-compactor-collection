#: src-en/data/text_blueprints.xml.append:93
msgid ""
"data/text_blueprints.xml.append$//text[@name=\"text_PLAYER_SHIP_TC_CONSTRUCTION_desc\"]"
msgstr ""
"Ceci est une version entièrement fonctionnelle du Mineur Kestrel de l'époque"
" où il était réellement utilisé pour l'extraction minière - avant que "
"TRACKER et sa bande ne le récupèrent."

#: src-en/data/text_blueprints.xml.append:94
msgid ""
"data/text_blueprints.xml.append$//text[@name=\"ship_PLAYER_SHIP_TC_CONSTRUCTION_unlock\"]"
