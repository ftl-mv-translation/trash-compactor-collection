#: src-en/data/text_blueprints.xml.append:136
msgid ""
"data/text_blueprints.xml.append$//text[@name=\"text_PLAYER_SHIP_SLUGTON_desc\"]"
msgstr ""
"BIENVENUE DANS LA [VERSION D'ESSAI] DU [vaisseau à difficulté modérée] !!! "
"JOUEZ MAINTENANT JOUEZ MAINTENANT - DEVENEZ [un gros bonnet] ! ACQUÉREZ "
"[UWU] !"

