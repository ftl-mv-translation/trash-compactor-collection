msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"TC_ROSEGOLD_DESTROY\"]/choice[1]/text"
msgstr "Arracher l'arme."

#: src-en/data/events_special_multiverse.xml.append:2116
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"TC_ROSEGOLD_DESTROY\"]/choice[1]/event/text"
