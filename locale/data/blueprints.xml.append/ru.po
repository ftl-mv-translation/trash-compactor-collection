#: src-en/data/blueprints.xml.append:6004
msgid "data/blueprints.xml.append$//weaponBlueprint[@name=\"NOVA_MK1\"]/desc"
msgstr ""
"Небольшое, надежное (?), достаточно мощное. Вероятно, одно из любимых орудий"
" ваших врагов."

#: src-en/data/blueprints.xml.append:6005
msgid "data/blueprints.xml.append$//weaponBlueprint[@name=\"NOVA_MK1\"]/tooltip"
msgstr "Лучевое оружие, 1 урон по корпусу, длина луча 30"

#: src-en/data/blueprints.xml.append:6033
msgid "data/blueprints.xml.append$//weaponBlueprint[@name=\"NOVA_MK2\"]/title"
