msgid "data/blueprints.xml.append$//augBlueprint[@name=\"SAVIOR_SHIELD\"]/desc"
msgstr ""
"A strange variation of Ancient tech, this Aether powered energy shield only "
"has 5 hitpoints, but heals your crew even without life support powered. "
