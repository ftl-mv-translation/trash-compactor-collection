" suddenly spring to life!"

#: src-en/data/events_special_storage.xml.append:2015
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_JOB_TRASH_COMPACT_CHOICE\"]/choice[3]/event/crewMember"
