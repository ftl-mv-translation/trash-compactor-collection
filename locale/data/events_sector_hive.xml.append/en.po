"data/events_sector_hive.xml.append$//event[@name=\"MANTIS_BOMB_FLAK_TRANSPORT\"]/choice[@req=\"mantis\"]/text"
msgstr "(Hive Mantis) Contact them with your Mantis."

#: src-en/data/events_sector_hive.xml.append:25
msgid ""
"data/events_sector_hive.xml.append$//event[@name=\"MANTIS_BOMB_FLAK_TRANSPORT\"]/choice[@req=\"mantis\"]/event/text"
msgstr ""
"\"Mantis on Federation ship? You wanting Bomb Flaks?\" The Mantis chuckles. "
"\"Hive disapprove selling to Federation, but I willing. After all, scrap "
"scrap!\" Even with your Mantis crewmember, you're surprised they're willing "
"to sell to you. You take a look at their catalogue."

