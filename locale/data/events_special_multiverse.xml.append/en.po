msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"ENCOUNTER_TC_ZOG_FIGHT\"]/beaconType/undiscoveredTooltip"
msgstr "I am waiting."

#: src-en/data/events_special_multiverse.xml.append:2554
msgid ""
"data/events_special_multiverse.xml.append$/dummyroot/FTL/event[@name=\"ENCOUNTER_TC_ZOG_FIGHT_NO\"]/text"
msgstr "There's nothing left to do."

#: src-en/data/events_special_multiverse.xml.append:2556
msgid ""
"data/events_special_multiverse.xml.append$/dummyroot/FTL/event[@name=\"ENCOUNTER_TC_ZOG_FIGHT_NO\"]/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_special_multiverse.xml.append:2560
msgid ""
"data/events_special_multiverse.xml.append$/dummyroot/FTL/event[@name=\"ENCOUNTER_TC_ZOG_FIGHT_NO\"]/choice[2]/text"
