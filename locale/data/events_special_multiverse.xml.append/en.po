msgstr "Rosegold + Adamantine."

#: src-en/data/events_special_multiverse.xml.append:2469
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"ENCOUNTER_TC_ZOG_CHOICE\"]/choice[1]/event/choice[3]/event/text"
msgstr ""
"The Architect's ship moves away to a safer distance and one of the Scrapper "
