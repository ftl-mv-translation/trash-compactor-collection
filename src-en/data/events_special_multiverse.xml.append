		<loadEventList seeded="false" first="true">
			<event name="ZOG_HAPPY" req="unique_zog"/>
			<event name="ZOG_MAD"/>
		</loadEventList>
	</event>

	<event name="ZOG_HAPPY"/>

	<event name="ZOG_MAD">
