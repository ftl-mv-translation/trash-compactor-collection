				</choice>
			</event>
		</choice>
		<choice>
			<text>No.</text>
			<event>
				<text>"Another time, then." They jump away.</text>
				<instantEscape/>
				<choice hidden="true">
					<text>Do something onboard the ship.</text>
					<event load="STORAGE_CHECK"/>
