<event name="SCRAPPER_ENCOUNTER_LIST">
	<loadEventList first="false" generate="true">
		<event name="SCRAPPER_ENCOUNTER_SHOP"/>
		<!--<event name="SCRAPPER_ENCOUNTER_BOMBER"/>-->
		<event name="SCRAPPER_ENCOUNTER_SUPPORT"/>
