<event name="KM_QUEST_1">
	<text>TRACKER is here - he seems busy, though. "Oh hi, you again... Please, uh, help me."</text>
	<beaconType id="map_icon_trash" global="true">
        <color r="110" g="32" b="9" a="1.0"/>
