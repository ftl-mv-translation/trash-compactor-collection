		<mod:findName type="event" name="SYLVAN_ROYAL_NORMAL">
<mod:findLike type="choice" start="0" limit="1">
<mod:findLike type="event">
<mod-append:choice req="LIST_CREW_LEAH" blue="true">
    <text>Have Leah stand next to you while you respond to her hail.</text>
	<event load="SYLVAN_ROYAL_LEAH_DIALOGUE"/>
</mod-append:choice>
</mod:findLike>
</mod:findLike>
</mod:findName>

<event name="SYLVAN_ROYAL_LEAH_DIALOGUE">
    <text>"No way. No way you did this. No way you found... ANOTHER LEAH? What about us? What about our rivalry, the most legendary rivalry to ever exist, and you found ANOTHER me? I thought we had something special, we've fought each other so many times, had so many amazing moments and you... you... you cheat on me!" Leah slams her fist down onto the table and leaps from her seat. "No more games captain, our rivalry is over, and only one of us is going to make it out of here alive. Ooh, but what if we both died at the same time, wouldn't that make for such a cool and epic mo-" You close communications and begin to charge your weapons.</text>
	<ship hostile="true"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="COMBAT_CHECK"/>
	</choice>
</event>

<mod:findName type="event" name="THE_JUDGES_ZOLTAN">
    <mod-append:choice req="LIST_CREW_SCRAPPER" blue="false">
        <text>Present a Scrapper.</text>
		<event>
			<text>"The... hoarders of the Lanius. Their greed for... scrap has changed them. To invite one upon your ship is... surprising. Yes, I am... impressed. Well done, traveler. Expect... rewards before your next journey."</text>
			<achievement silent="false">ACH_BOON_TCC_SCRAPPER</achievement>
			<metaVariable name="prof_z_boon_tcc_scrapper" op="set" val="1"/>
            <variable name="ach_boon_tcc_scrapper" op="set" val="1"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="THE_JUDGES_ZOLTAN_ADVICE"/>
			</choice>
		</event>
    </mod-append:choice>
</mod:findName>

<mod:findName type="event" name="THE_JUDGES_VARIABLE_CLEAR">
    <mod-append:metaVariable name="prof_z_boon_tcc_scrapper" op="set" val="0"/>
</mod:findName>


<event name="HELL">
	<environment type="sun"/>
	<environment type="asteroid"/>
	<environment type="pulsar"/>
	<environment type="PDS" target="player"/>
	<triggeredEvent name="BLUE_GIANT" event="BLUE_GIANT_FLARE" seeded="true" thisFight="false" clearOnJump="true" loops="999999999" minTime="24.0" maxTime="30.0">
		<warningMessage id="warning_solar_flare" x="825" y="30" time="5.0" centerText="true" flash="true" sound="environWarning" useWarningLine="false"/>
	</triggeredEvent>
	<triggeredEvent name="GRAVASTAR" event="GRAVITY_SURGE" seeded="true" thisFight="false" clearOnJump="true" loops="999999999" minTime="18.0" maxTime="24.0">
		<warningMessage id="warning_gravity_wave" x="825" y="30" time="5.0" centerText="true" flash="true" sound="environWarning" useWarningLine="false"/>
	</triggeredEvent>
	<variable name="loc_environment_gravity" op="set" val="1"/>
    <variable name="loc_environment_blue_giant" op="set" val="1"/>
</event>
</FTL>
